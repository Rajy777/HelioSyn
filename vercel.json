{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "PYTHONPATH": "."
  },
  "functions": {
    "api/*.py": {
      "excludeFiles": "{node_modules,src,dist,public,backend/venv,backend/__pycache__,.git,.github}/**"
    }
  }
}
